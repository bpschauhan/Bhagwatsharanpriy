generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MeaningLayerType {
  SIMPLE
  BEGINNER
  DEEP
  PRACTICAL
  PHILOSOPHICAL
  SCIENTIFIC_PARALLEL
}

enum SourceType {
  SCRIPTURE
  COMMENTARY
  TRANSLATION
  REFERENCE
  SCHOLARLY
  HISTORICAL
  MODERN_ANALYSIS
}

enum UserRole {
  ADMIN
  EDITOR
  REVIEWER
  CONTRIBUTOR
}

enum VerificationStatus {
  DRAFT
  REVIEW
  VERIFIED
  DISPUTED
  ARCHIVED
}

enum ContentEntityType {
  BOOK
  CHAPTER
  VERSE
  MEANING_LAYER
  CONCEPT
  COMMENTARY
  SOURCE
  KNOWLEDGE_NODE
  KNOWLEDGE_EDGE
  RELATED_CONCEPT
}

enum AuditAction {
  CREATED
  UPDATED
  SUBMITTED_FOR_REVIEW
  APPROVED
  DISPUTED
  ARCHIVED
  REVISION_CREATED
  ROLLBACK_REQUESTED
}

enum KnowledgeNodeType {
  TRADITION
  SCRIPTURE
  BOOK
  CHAPTER
  CONCEPT
  PHILOSOPHY_SCHOOL
  PRACTICE
  COMMENTARY
}

enum KnowledgeRelationshipType {
  BELONGS_TO
  INFLUENCED
  RELATED_TO
  EXPLAINS
  COMMENTARY_ON
  DERIVED_FROM
}

model WisdomText {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  tradition   String
  summary     String
  status      ContentStatus @default(DRAFT)
  lessons     Lesson[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Lesson {
  id            String     @id @default(cuid())
  wisdomTextId  String
  wisdomText    WisdomText @relation(fields: [wisdomTextId], references: [id], onDelete: Cascade)
  title         String
  slug          String
  order         Int
  body          String
  shlokas       Shloka[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([wisdomTextId, slug])
  @@index([wisdomTextId, order])
}

model Shloka {
  id              String   @id @default(cuid())
  lessonId        String
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  sanskrit        String
  transliteration String
  wordMeaning     String
  essence         String
  reflection      String
  order           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([lessonId, order])
}

model Book {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  subtitle        String?
  tradition       String
  difficulty      DifficultyLevel @default(BEGINNER)
  summary         String
  beginnerSummary String
  status          ContentStatus   @default(PUBLISHED)
  verificationStatus VerificationStatus @default(DRAFT)
  confidenceLevel Int             @default(0)
  interpretationLabel String?
  reviewNotes     String?
  reviewedById    String?
  reviewedAt      DateTime?
  chapters        Chapter[]
  knowledgeNodes  KnowledgeNode[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, difficulty])
  @@index([verificationStatus, confidenceLevel])
  @@index([tradition])
}

model Chapter {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  number    Int
  slug      String
  title     String
  summary   String
  overview  String
  verificationStatus VerificationStatus @default(DRAFT)
  confidenceLevel Int      @default(0)
  interpretationLabel String?
  reviewNotes String?
  reviewedById String?
  reviewedAt DateTime?
  verses    Verse[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookId, number])
  @@unique([bookId, slug])
  @@index([bookId, number])
  @@index([verificationStatus])
}

model Verse {
  id                   String          @id @default(cuid())
  chapterId            String
  chapter              Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  number               Int
  slug                 String
  sanskrit             String
  transliteration      String
  wordByWord           String
  practicalApplication String
  philosophyInsight    String
  status               ContentStatus   @default(PUBLISHED)
  verificationStatus   VerificationStatus @default(DRAFT)
  confidenceLevel      Int             @default(0)
  interpretationLabel  String?
  reviewNotes          String?
  reviewedById         String?
  reviewedAt           DateTime?
  meaningLayers        MeaningLayer[]
  concepts             VerseConcept[]
  commentaries         Commentary[]
  sources              VerseSource[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([chapterId, number])
  @@unique([chapterId, slug])
  @@index([chapterId, number])
  @@index([status])
  @@index([verificationStatus, confidenceLevel])
}

model MeaningLayer {
  id        String           @id @default(cuid())
  verseId   String
  verse     Verse            @relation(fields: [verseId], references: [id], onDelete: Cascade)
  type      MeaningLayerType
  title     String
  body      String
  order     Int
  verificationStatus VerificationStatus @default(DRAFT)
  confidenceLevel Int      @default(0)
  interpretationLabel String?
  reviewNotes String?
  reviewedById String?
  reviewedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([verseId, type])
  @@index([verseId, order])
  @@index([type])
  @@index([verificationStatus])
}

model Concept {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  category    String
  description String
  verificationStatus VerificationStatus @default(DRAFT)
  confidenceLevel Int             @default(0)
  interpretationLabel String?
  reviewNotes String?
  reviewedById String?
  reviewedAt DateTime?
  verses      VerseConcept[]
  knowledgeNodes KnowledgeNode[]
  relatedFrom RelatedConcept[] @relation("RelatedConceptFrom")
  relatedTo   RelatedConcept[] @relation("RelatedConceptTo")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([category])
  @@index([verificationStatus, confidenceLevel])
}

model VerseConcept {
  verseId   String
  conceptId String
  verse     Verse   @relation(fields: [verseId], references: [id], onDelete: Cascade)
  concept   Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  relevance String
  order     Int     @default(0)

  @@id([verseId, conceptId])
  @@index([conceptId])
  @@index([verseId, order])
}

model Commentary {
  id                 String   @id @default(cuid())
  verseId            String
  verse              Verse    @relation(fields: [verseId], references: [id], onDelete: Cascade)
  sourceId           String?
  source             Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  author             String
  tradition          String
  title              String
  body               String
  interpretationNote String
  order              Int
  verificationStatus VerificationStatus @default(DRAFT)
  confidenceLevel    Int      @default(0)
  interpretationLabel String?
  reviewNotes        String?
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([verseId, order])
  @@index([sourceId])
  @@index([tradition])
  @@index([verificationStatus])
}

model Source {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  author       String?
  translator   String?
  publisher    String?
  url          String?
  sourceType   SourceType
  citation     String
  publication  String?
  notes        String?
  credibilitySummary String?
  credibilityScore Int        @default(0)
  verificationStatus VerificationStatus @default(DRAFT)
  confidenceLevel Int         @default(0)
  reviewNotes String?
  reviewedById String?
  reviewedAt DateTime?
  commentaries Commentary[]
  verses       VerseSource[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([sourceType])
  @@index([verificationStatus, credibilityScore])
}

model VerseSource {
  verseId  String
  sourceId String
  verse    Verse  @relation(fields: [verseId], references: [id], onDelete: Cascade)
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  locator  String
  note     String?

  @@id([verseId, sourceId])
  @@index([sourceId])
}

model Tradition {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  summary     String
  nodes       KnowledgeNode[]
  schools     PhilosophySchool[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model PhilosophySchool {
  id          String          @id @default(cuid())
  traditionId String?
  tradition   Tradition?      @relation(fields: [traditionId], references: [id], onDelete: SetNull)
  slug        String          @unique
  name        String
  summary     String
  nodes       KnowledgeNode[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([traditionId])
}

model KnowledgeNode {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  subtitle    String?
  summary     String
  nodeType    KnowledgeNodeType
  traditionId String?
  tradition   Tradition?        @relation(fields: [traditionId], references: [id], onDelete: SetNull)
  schoolId    String?
  school      PhilosophySchool? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  conceptId   String?
  concept     Concept?          @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  bookId      String?
  book        Book?             @relation(fields: [bookId], references: [id], onDelete: SetNull)
  verificationStatus VerificationStatus @default(DRAFT)
  confidenceLevel Int           @default(0)
  interpretationLabel String?
  reviewNotes String?
  reviewedById String?
  reviewedAt DateTime?
  outgoing    KnowledgeEdge[]   @relation("KnowledgeEdgeSource")
  incoming    KnowledgeEdge[]   @relation("KnowledgeEdgeTarget")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([nodeType])
  @@index([traditionId])
  @@index([schoolId])
  @@index([conceptId])
  @@index([bookId])
  @@index([verificationStatus])
}

model KnowledgeEdge {
  id               String                    @id @default(cuid())
  sourceNodeId     String
  targetNodeId     String
  sourceNode       KnowledgeNode             @relation("KnowledgeEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode       KnowledgeNode             @relation("KnowledgeEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  relationshipType KnowledgeRelationshipType
  label            String
  summary          String
  bidirectional    Boolean                   @default(false)
  weight           Int                       @default(1)
  verificationStatus VerificationStatus      @default(DRAFT)
  confidenceLevel  Int                       @default(0)
  interpretationLabel String?
  reviewNotes      String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@unique([sourceNodeId, targetNodeId, relationshipType])
  @@index([targetNodeId])
  @@index([relationshipType])
  @@index([sourceNodeId, weight])
  @@index([verificationStatus])
}

model RelatedConcept {
  fromConceptId    String
  toConceptId      String
  fromConcept      Concept                   @relation("RelatedConceptFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  toConcept        Concept                   @relation("RelatedConceptTo", fields: [toConceptId], references: [id], onDelete: Cascade)
  relationshipType KnowledgeRelationshipType
  label            String
  summary          String
  bidirectional    Boolean                   @default(true)
  weight           Int                       @default(1)
  verificationStatus VerificationStatus      @default(DRAFT)
  confidenceLevel  Int                       @default(0)
  interpretationLabel String?
  reviewNotes      String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@id([fromConceptId, toConceptId, relationshipType])
  @@index([toConceptId])
  @@index([relationshipType])
  @@index([verificationStatus])
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  role      UserRole   @default(CONTRIBUTOR)
  active    Boolean    @default(true)
  revisions Revision[]
  reviews   ContentReview[]
  auditLogs AuditLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([role, active])
}

model Revision {
  id          String            @id @default(cuid())
  entityType  ContentEntityType
  entityId    String
  version     Int
  title       String
  summary     String?
  snapshot    Json
  changeNote  String?
  authorId    String?
  author      User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId, createdAt])
  @@index([authorId])
}

model ContentReview {
  id          String             @id @default(cuid())
  entityType  ContentEntityType
  entityId    String
  status      VerificationStatus @default(REVIEW)
  confidenceLevel Int            @default(0)
  reviewerId  String?
  reviewer    User?              @relation(fields: [reviewerId], references: [id], onDelete: SetNull)
  sourceNotes String?
  truthNotes  String?
  decisionNotes String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([entityType, entityId])
  @@index([status, confidenceLevel])
  @@index([reviewerId])
}

model AuditLog {
  id          String            @id @default(cuid())
  actorId     String?
  actor       User?             @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action      AuditAction
  entityType  ContentEntityType
  entityId    String
  message     String
  metadata    Json?
  createdAt   DateTime          @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action])
}
